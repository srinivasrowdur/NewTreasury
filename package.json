{
  "name": "investment-research-lab-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "research:run": "python3 -m research.run_lab --mandate balanced --experiments 36 --use-llm --fallback-data",
    "research:conservative": "python3 -m research.run_lab --mandate conservative --experiments 36 --use-llm --fallback-data",
    "research:growth": "python3 -m research.run_lab --mandate growth --experiments 36 --use-llm --fallback-data",
    "research:public-data": "python3 -m research.run_lab --mandate balanced --experiments 36 --use-llm",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
